# Deploy secrets for deploy/deploy_domain.sh (and the Python orchestrator).
#
# Copy to ~/.config/legal-agent/deploy.env (or point DEPLOY_ENV / LEGAL_DEPLOY_ENV_FILE
# at it), fill in real values, and `chmod 600` it. NEVER commit real secrets.
#
# deploy_domain.sh sources this file and renders the remote /opt/legal-agent/.env
# from it plus fixed, non-secret config (public URL, issuer, proxy selection).

# --- Required by deploy_domain.sh (the always-on domain deploy) --------------
# AnyIP residential/mobile proxy credentials (Argentina egress for browser sources).
LEGAL_ANYIP_USER=
LEGAL_ANYIP_PASS=
# Capsolver API key (PTN, PJN Expedientes, Sentencias SCBA captchas).
LEGAL_CAPSOLVER_API_KEY=
# MCP OAuth: token signing key and the single-user login-form secret.
# Generate once and KEEP STABLE across redeploys, or previously issued bearer
# tokens / connector authorizations stop validating:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"   # signing key
LEGAL_MCP_OAUTH_SIGNING_KEY=
LEGAL_MCP_OAUTH_LOGIN_SECRET=
# Accepted key for the x-api-key-protected /v1 HTTP API routes.
LEGAL_API_KEY=

# --- Optional ----------------------------------------------------------------
# Floxy proxy credentials (alternate proxy backend; not used when provider=anyip).
LEGAL_FLOXY_USER=
LEGAL_FLOXY_PASS=
# Cloudzy Developer API token (only needed to provision/destroy VPSes via the
# Python orchestrator / cloudzy_cli; deploy_domain.sh targets an existing host).
CLOUDZY_API_TOKEN=
