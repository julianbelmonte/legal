# Deploy secrets for the Python deploy orchestrator (`python -m deploy.deploy`)
# and the Cloudzy CLI (`python -m deploy.cloudzy_cli`).
#
# Copy to ~/.config/legal-agent/deploy.env (or point --deploy-env-file /
# LEGAL_DEPLOY_ENV_FILE at it), fill in real values, and `chmod 600` it.
# NEVER commit real secrets.
#
# The orchestrator resolves these (env vars override file values), writes the
# remote /opt/legal-agent/.env from them plus fixed non-secret config (the
# bare-domain public URL/issuer, Argentine AnyIP proxy selection, token TTL),
# installs Caddy, and fronts the app at https://<domain> (default
# mcp.arglegal.live). On `deploy --fresh` it also repoints the Namecheap DNS at
# the new IP via the namecheap-domains skill.

# --- Required for a runtime deploy -------------------------------------------
# AnyIP residential/mobile proxy credentials (Argentina egress for browser
# sources incl. CSJN). Seeded with LEGAL_PROXY_ENABLED/PROVIDER/COUNTRY defaults.
LEGAL_ANYIP_USER=
LEGAL_ANYIP_PASS=
# Capsolver API key (PTN, PJN Expedientes, Sentencias SCBA captchas).
LEGAL_CAPSOLVER_API_KEY=
# MCP OAuth: token signing key and the single-user login-form secret.
# Generate once and KEEP STABLE across redeploys, or previously issued bearer
# tokens / connector authorizations stop validating:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"   # signing key
LEGAL_MCP_OAUTH_SIGNING_KEY=
LEGAL_MCP_OAUTH_LOGIN_SECRET=
# Accepted key for the x-api-key-protected /v1 HTTP API routes.
LEGAL_API_KEY=

# --- Required to provision / destroy a VPS -----------------------------------
# Cloudzy Developer API token. Used by BOTH `python -m deploy.deploy`
# (provision/reuse/destroy) and `python -m deploy.cloudzy_cli`. Resolved from
# this file or the CLOUDZY_API_TOKEN env var; never printed, never committed.
CLOUDZY_API_TOKEN=

# --- Optional ----------------------------------------------------------------
# Floxy proxy credentials (alternate proxy backend; not used when provider=anyip).
LEGAL_FLOXY_USER=
LEGAL_FLOXY_PASS=
# Override the seeded runtime defaults if needed (otherwise the orchestrator
# sets LEGAL_PROXY_ENABLED=true / PROVIDER=anyip / COUNTRY=ar and a 24h TTL):
# LEGAL_PROXY_ENABLED=true
# LEGAL_PROXY_PROVIDER=anyip
# LEGAL_PROXY_COUNTRY=ar
# LEGAL_MCP_OAUTH_TOKEN_TTL_SECONDS=86400
#
# NOTE: ngrok is no longer used (Caddy + the Namecheap domain replaced it); no
# NGROK_AUTHTOKEN is required.
